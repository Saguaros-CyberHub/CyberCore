# =============================================================================
# CyberHub — Caddy Reverse Proxy
# =============================================================================
# CYBERHUB_HOST controls the public site:
#
#   yourdomain.example.edu   — HTTPS with automatic Let's Encrypt certificate
#   :80                      — HTTP only, no certificate (offline / LAN mode)
#
# A SECOND, internal-only HTTP listener on :80 is always defined below so that
# in-cluster clients (lane gateways, GOAD controllers, anything calling
# /api/lane-bootstrap from inside the lab) can reach the app over plain HTTP
# without dealing with TLS handshakes against the public Let's Encrypt cert.
# This avoids:
#   - BusyBox wget on Alpine LXCs failing the public-cert handshake
#   - Hairpin-NAT routing problems when an internal host resolves the public
#     hostname to a public IP and the lab edge router doesn't NAT back in
#
# Reachability of the internal :80 listener is gated at the network layer by
# OPNsense firewall rules (only lab subnets and the orchestrator's own
# interface), so it isn't exposed to the public internet.
# =============================================================================

# --- Public site (HTTPS via Let's Encrypt when CYBERHUB_HOST is a domain) ----
{$CYBERHUB_HOST} {

    # Guacamole remote console — same-origin proxy so the browser and Guacamole
    # share an origin (satisfies Guacamole's X-Frame-Options: SAMEORIGIN).
    # Caddy upgrades WebSocket connections automatically.
    handle /guacamole* {
        reverse_proxy guacamole:8080
    }

    # CyberHub application
    handle {
        reverse_proxy app:3000
    }
}

# --- Internal HTTP listener (no TLS, no redirect) ----------------------------
# Catches any direct-IP request on :80 — e.g. lane gateways hitting
# http://100.100.20.50/api/lane-bootstrap, lane web VMs pulling vuln-app images
# from /api/profile-deploy/image/<token>. Same routes as the public site.
#
# `http://` prefix is REQUIRED — without it, Caddy treats this as a site that
# COULD do HTTPS, and the auto-HTTPS engine adds a 308 HTTP→HTTPS redirect on
# behalf of any HTTPS-eligible site (including {$CYBERHUB_HOST}), which then
# bounces lane requests to https://<ip> where the cert doesn't match and the
# lane has no Let's Encrypt root anyway. The explicit `http://` opts this
# block out of auto-HTTPS so it stays a plain HTTP listener.
#
# Reachability of the internal :80 listener is gated at the network layer by
# OPNsense firewall rules (only lab subnets and the orchestrator's own
# interface), so it isn't exposed to the public internet.
http://:80 {
    handle /guacamole* {
        reverse_proxy guacamole:8080
    }
    handle {
        reverse_proxy app:3000
    }
}
