{
  "_comment": "Copy to config/site.json (gitignored) and fill in real values. Only the 'cluster' block below is actually read — see front-end/src/utils/site-config.js for the exact keys/defaults. install.sh generates this file for you; this example is for manual/reference setups.",

  "site": {
    "name": "cyberhub-prod",
    "timezone": "America/Phoenix",
    "domain": "cyberhub.example.com"
  },

  "cluster": {
    "physical_cluster_details": {
      "cyberhub-node-0": { "ip": "100.100.10.10" }
    },

    "networking": {
      "module_networks": {
        "crucible":  { "bridge": "crucible",  "gateway": "100.102.0.1", "subnet_base": "100.102", "cidr": "/16" },
        "cyberlabs": { "bridge": "cyberlabs", "gateway": "100.103.0.1", "subnet_base": "100.103", "cidr": "/16" },
        "forge":     { "bridge": "forge",     "gateway": "100.104.0.1", "subnet_base": "100.104", "cidr": "/16" }
      },

      "v2_lab_network": {
        "bridge":      "vmbr0",
        "vlan_tag":    60,
        "subnet_base": "100.100.60",
        "gateway":     "100.100.60.1",
        "cidr":        "/24"
      },

      "v1_lane_subnet": {
        "base3":      "192.18.0",
        "cidr":       "192.18.0.0/24",
        "gateway_ip": "192.18.0.1",
        "netmask24":  "255.255.255.0"
      }
    },

    "scheduling": {
      "min_free_mem_gb":       8,
      "min_free_disk_gb":      20,
      "max_concurrent_lanes":  5,
      "max_concurrent_clones": 4,
      "node_score_weights":    { "cpu": 0.35, "mem": 0.55, "disk": 0.10 }
    }
  }
}
