{
  "key": "ciab",
  "name": "Clinic-in-a-Box",
  "icon": "🏥",
  "description": "Cyber risk assessment training with AI-powered interviews and profiles",
  "category": "plugin",
  "color": "#1e40af",
  "entryUrl": "/ciab/dashboard",
  "displayOrder": 10,

  "database": {
    "name": "clinic_db",
    "migrations": "migrations/"
