# ============================================================================
# CYBERHUB — Production Environment Configuration
# Copy to .env and fill in values
# ============================================================================

TZ=America/Phoenix

# Reverse Proxy / Public hostname
# Set to your domain for automatic HTTPS (Let's Encrypt via Caddy).
# Set to :80 for HTTP-only LAN/offline mode. See docs/offline-mode.md.
CYBERHUB_HOST=yourdomain.example.edu

# Core Database (cybercore_db — single source of truth)
CORE_DB_USER=cyberhub
CORE_DB_PASSWORD=REPLACE_ME
CORE_DB_NAME=cybercore_db
CORE_ENABLED_MODULES=crucible,cyberlabs,forge,library,university,wiki

# First admin account seeded at database init time
ADMIN_EMAIL=admin@yourdomain.example.edu

# App Security
JWT_SECRET=REPLACE_ME
SESSION_SECRET=REPLACE_ME
# Required in production: HMAC key for /vuln-assets signed download URLs.
# Generate with: openssl rand -hex 32  (the app refuses to start signing with
# the dev fallback when NODE_ENV=production)
VULN_ASSETS_SECRET=REPLACE_ME

# PGAdmin
PGADMIN_EMAIL=admin@cybercore.local
PGADMIN_PASSWORD=REPLACE_ME

# FTP
FTP_USER=cybercore
FTP_PASSWORD=REPLACE_ME

# Apache Guacamole (runs inside the compose stack — see docker-compose.yml)
#
# Guacamole service account (used by CyberCore backend to call Guacamole API).
# Never exposed to the browser.
GUAC_ADMIN_USER=guacadmin
GUAC_ADMIN_PASSWORD=REPLACE_ME

# Guacamole PostgreSQL database (hosted on the shared postgres container).
GUAC_DB_NAME=guacamole_db
GUAC_DB_USER=guacamole_user
GUAC_DB_PASSWORD=REPLACE_ME
# Generate encryption key with: openssl rand -hex 32
GUAC_ENCRYPT_KEY=REPLACE_ME

# Encrypts TOTP/MFA secrets at rest (pgcrypto). Generate with: openssl rand -hex 32
# If unset, falls back to GUAC_ENCRYPT_KEY.
MFA_ENCRYPT_KEY=REPLACE_ME

# GUAC_ENABLED and GUAC_PUBLIC_BASE_URL are set automatically in docker-compose.yml
# and do not need to be set here when running the full compose stack.

# Proxmox
PROXMOX_API_URL=https://100.100.10.10:8006
PROXMOX_TOKEN_ID=root@pam!clinic-app-token
PROXMOX_TOKEN_SECRET=REPLACE_ME

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=2000
RATE_LIMIT_WINDOW_MS=900000